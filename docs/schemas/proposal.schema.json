{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Brehove/margent/docs/schemas/proposal.schema.json",
  "title": "Margent Proposal Record",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "documentId",
    "threadIds",
    "adapterId",
    "createdAt",
    "updatedAt",
    "status",
    "baseContentHash",
    "responseMode",
    "summary",
    "assistantMessage",
    "computedDiff",
    "warnings",
    "resolveThreadIds"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "documentId": { "type": "string", "minLength": 1 },
    "threadIds": { "type": "array", "items": { "type": "string" } },
    "adapterId": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "stale", "failed"] },
    "baseContentHash": { "type": "string", "pattern": "^sha256:" },
    "responseMode": { "type": "string" },
    "summary": { "type": "string" },
    "assistantMessage": { "type": "string" },
    "updatedDocumentText": { "type": ["string", "null"] },
    "unifiedDiff": { "type": ["string", "null"] },
    "computedDiff": { "type": "string" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "resolveThreadIds": { "type": "array", "items": { "type": "string" } },
    "stderr": { "type": ["string", "null"] },
    "errorMessage": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}

