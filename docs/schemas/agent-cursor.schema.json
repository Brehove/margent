{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Brehove/margent/docs/schemas/agent-cursor.schema.json",
  "title": "Margent Agent Cursor Record",
  "type": "object",
  "required": ["agentId"],
  "properties": {
    "agentId": { "type": "string", "minLength": 1 },
    "providerId": { "type": ["string", "null"] },
    "adapterId": { "type": ["string", "null"] },
    "lastSeenEventId": { "type": ["string", "null"] },
    "lastSyncedAt": { "type": ["string", "null"], "format": "date-time" },
    "lastSyncStatus": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}

