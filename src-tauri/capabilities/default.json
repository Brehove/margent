{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:allow-watch",
    {
      "identifier": "fs:scope",
      "allow": ["$HOME/**", "$TEMP/**", "/tmp/**", "/private/tmp/**"]
    },
    "fs:allow-unwatch",
    "deep-link:default",
    "notification:default",
    "updater:default"
  ]
}
