# Never commit local review content, provider credentials, generated bundles,
# logs, or machine-specific overrides. Public release hygiene depends on this.

# Secrets and machine-local overrides
.env
.env.*
!.env.example
*.local
*.local.*
AGENTS.local.md
docs/internal/

# Local review/workspace state
/.mdreview/
.mdreview/
/.codex/
/.claude/settings.local.json
/.mcp.json

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

/node_modules/
/dist/
/dist-ssr/

# Rust/Tauri build output
/cli/target/
/crates/*/target/
/src-tauri/target/
/src-tauri/gen/schemas/
/src-tauri/target/release/bundle/
*.dmg
*.app
__pycache__/
*.py[cod]

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
